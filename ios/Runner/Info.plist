<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Delivery App</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>Delivery App</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<!-- <string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string> -->
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	    <!-- Google Maps API Key -->
        <key>GMSApiKey</key>
        <string>AIzaSyAbmRHOMGItXC6dcajVKckbBpsrygRouts</string>

        <!-- Location Permissions -->
        <key>NSLocationWhenInUseUsageDescription</key>
        <string>This app needs your location to show nearby deliveries.</string>

        <key>NSLocationAlwaysUsageDescription</key>
        <string>This app needs your location even when running in the background.</string>

        <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
        <string>This app needs your location for better delivery tracking.</string>


        <!-- Background Location Support -->
        <key>UIBackgroundModes</key>
        <array>
            <string>location</string>
        </array>

        <!-- Camera Permission -->
        <key>NSCameraUsageDescription</key>
        <string>This app needs camera access to capture parcel photos.</string>

        <!-- Photo Library Permission -->
        <key>NSPhotoLibraryUsageDescription</key>
        <string>This app needs photo library access to upload parcel images.</string>

        <key>NSPhotoLibraryAddUsageDescription</key>
        <string>This app needs permission to save photos to your library.</string>

        <!-- Microphone (for video calls) -->
        <key>NSMicrophoneUsageDescription</key>
        <string>This app needs microphone access for voice and video calls.</string>

        <!-- Notification Permission (handled at runtime; no plist key required for iOS, but included for clarity) -->

        <!-- ===== Facebook Login Configuration ===== -->
        <!-- Replace YOUR_FACEBOOK_APP_ID and YOUR_FACEBOOK_CLIENT_TOKEN with real values -->
        <!-- from https://developers.facebook.com/ > Your App > Settings > Basic -->
        <key>FacebookAppID</key>
        <string>YOUR_FACEBOOK_APP_ID</string>

        <key>FacebookClientToken</key>
        <string>YOUR_FACEBOOK_CLIENT_TOKEN</string>

        <key>FacebookDisplayName</key>
        <string>Delivery App</string>

        <!-- URL Schemes required for Facebook Login OAuth redirect -->
        <key>CFBundleURLTypes</key>
        <array>
            <!-- Facebook Login callback URL scheme: fb{YOUR_FACEBOOK_APP_ID} -->
            <dict>
                <key>CFBundleURLSchemes</key>
                <array>
                    <string>fbYOUR_FACEBOOK_APP_ID</string>
                </array>
            </dict>
        </array>

        <!-- Allows the app to open the Facebook app if installed -->
        <key>LSApplicationQueriesSchemes</key>
        <array>
            <string>fbapi</string>
            <string>fb-messenger-share-api</string>
            <string>fbauth2</string>
            <string>fbshareextension</string>
        </array>

</dict>
</plist>
